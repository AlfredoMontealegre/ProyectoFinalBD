  <DataSources>
    <DataSource Name="Roman">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=Roman;Initial Catalog=MantenimientosUAMDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>1f7e2e3a-725b-46de-b463-9d0ad68b3678</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Roman</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT
    t.idTecnico,
    t.nombreTecnico,
    t.telefono,
    t.correo,
    t.departamento,
    COUNT(m.idMantenimiento) AS TotalMantenimientos
FROM Seguridad.Tecnico t
LEFT JOIN Mantenimiento.Mantenimiento m
    ON t.idTecnico = m.idTecnico
    AND m.deleted_at IS NULL
WHERE 
    t.deleted_at IS NULL
GROUP BY
    t.idTecnico,
    t.nombreTecnico,
    t.telefono,
    t.correo,
    t.departamento
ORDER BY 
    TotalMantenimientos DESC,
    t.nombreTecnico;</CommandText>
      </Query>
      <Fields>
        <Field Name="idTecnico">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>idTecnico</DataField>
        </Field>
        <Field Name="nombreTecnico">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreTecnico</DataField>
        </Field>
        <Field Name="telefono">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>telefono</DataField>
        </Field>
        <Field Name="correo">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>correo</DataField>
        </Field>
        <Field Name="departamento">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>departamento</DataField>
        </Field>
        <Field Name="TotalMantenimientos">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TotalMantenimientos</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
