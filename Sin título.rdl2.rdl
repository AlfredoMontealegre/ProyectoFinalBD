  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT s.codigoSalon, COUNT(d.idDispositivo) AS Total
FROM Mantenimiento.Dispositivo d
JOIN Mantenimiento.Salon s ON d.idSalon = s.idSalon
GROUP BY s.codigoSalon;
</CommandText>
      </Query>
      <Fields>
        <Field Name="codigoSalon">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>codigoSalon</DataField>
        </Field>
        <Field Name="Total">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Total</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
