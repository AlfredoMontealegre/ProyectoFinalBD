  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=Roman;Initial Catalog=MantenimientosUAMDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>9214f3d8-78c6-4103-80cd-543fff3615eb</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT
    t.nombreTecnico,
    t.departamento,
    tm.nombreTipoMantenimiento,
    COUNT(m.idMantenimiento) AS TotalPorTipo
FROM Seguridad.Tecnico t
INNER JOIN Mantenimiento.Mantenimiento m
    ON t.idTecnico = m.idTecnico
INNER JOIN Catalogo.TipoMantenimiento tm
    ON m.idTipoMantenimiento = tm.idTipoMantenimiento
WHERE 
    t.deleted_at IS NULL
    AND m.deleted_at IS NULL
GROUP BY
    t.nombreTecnico,
    t.departamento,
    tm.nombreTipoMantenimiento
ORDER BY
    t.nombreTecnico,
    tm.nombreTipoMantenimiento;</CommandText>
      </Query>
      <Fields>
        <Field Name="nombreTecnico">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreTecnico</DataField>
        </Field>
        <Field Name="departamento">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>departamento</DataField>
        </Field>
        <Field Name="nombreTipoMantenimiento">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreTipoMantenimiento</DataField>
        </Field>
        <Field Name="TotalPorTipo">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TotalPorTipo</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
