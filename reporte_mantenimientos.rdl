      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=SANTANA;Initial Catalog=MantenimientoUAMDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>de40d80d-354e-4b02-bec8-f314c7911adb</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Dsmantenimiento">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT tm.nombreTipoMantenimiento, COUNT(*) AS Total
FROM Mantenimiento.Mantenimiento m
JOIN Catalogo.TipoMantenimiento tm ON m.idTipoMantenimiento = tm.idTipoMantenimiento
GROUP BY tm.nombreTipoMantenimiento;
</CommandText>
      </Query>
      <Fields>
        <Field Name="nombreTipoMantenimiento">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreTipoMantenimiento</DataField>
        </Field>
        <Field Name="Total">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Total</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
