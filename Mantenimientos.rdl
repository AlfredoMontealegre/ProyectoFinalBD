  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Roman</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT
    t.idTecnico,
    t.nombreTecnico,
    t.telefono,
    t.correo,
    t.departamento,
    m.idMantenimiento,
    m.fechaMantenimiento,
    tm.nombreTipoMantenimiento,
    d.codigoDispositivo,
    td.nombreTipo AS TipoDispositivo,
    ed.estado AS EstadoDispositivo,
    s.codigoSalon,
    s.piso,
    e.nombreEdificio,
    m.observacion
FROM Seguridad.Tecnico t
INNER JOIN Mantenimiento.Mantenimiento m
    ON t.idTecnico = m.idTecnico
INNER JOIN Catalogo.TipoMantenimiento tm
    ON m.idTipoMantenimiento = tm.idTipoMantenimiento
INNER JOIN Mantenimiento.Dispositivo d
    ON m.idDispositivo = d.idDispositivo
INNER JOIN Catalogo.TipoDispositivo td
    ON d.idTipoDispositivo = td.idTipoDispositivo
INNER JOIN Catalogo.EstadoDispositivo ed
    ON d.idEstado = ed.idEstado
INNER JOIN Mantenimiento.Salon s
    ON d.idSalon = s.idSalon
INNER JOIN Catalogo.Edificio e
    ON s.idEdificio = e.idEdificio
WHERE 
    t.deleted_at IS NULL
    AND m.deleted_at IS NULL
ORDER BY 
    t.nombreTecnico,
    m.fechaMantenimiento DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="idTecnico">
