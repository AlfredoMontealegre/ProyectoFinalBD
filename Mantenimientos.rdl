  <DataSources>
    <DataSource Name="Roman">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=Roman;Initial Catalog=MantenimientosUAMDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>9e79b89e-02f5-49d0-8da7-38ef0f0d2269</rd:DataSourceID>
